generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  fullname         String
  phone            String?
  password         String
  isAdmin          Boolean   @default(false)
  twoFactorEnabled Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  /// Soft delete — non-null means the record is archived/hidden.
  deletedAt        DateTime?

  securityTokens UserSecurityToken[]
  posts          Post[]

  @@index([email])
  @@index([id])
  @@index([deletedAt])
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique @db.VarChar(100)
  slug      String    @unique @db.VarChar(120)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  /// Soft delete — non-null means the record is archived/hidden.
  deletedAt DateTime?

  posts Post[]

  @@index([slug])
  @@index([name])
  @@index([deletedAt])
}

model Post {
  id          String    @id @default(uuid())
  slug        String    @unique @db.VarChar(255)
  title       String    @db.VarChar(255)
  excerpt     String    @db.VarChar(500)
  content     String // sanitized HTML from the rich-text editor
  coverImage  String?   @db.VarChar(500)
  readTime    String    @db.VarChar(50)
  isPublished Boolean   @default(false)
  isFeatured  Boolean   @default(false)
  publishDate DateTime?

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  /// Soft delete — non-null means the record is archived/hidden.
  deletedAt DateTime?

  @@index([slug])
  @@index([isPublished])
  @@index([isFeatured])
  @@index([categoryId])
  @@index([authorId])
  @@index([publishDate])
  @@index([deletedAt])
}

/// Whether a project was built for a client or as a personal side project —
/// the public site groups projects under separate headings by this.
enum ProjectType {
  CLIENT
  SIDE
}

model Project {
  id           String      @id @default(uuid())
  slug         String      @unique @db.VarChar(255)
  title        String      @db.VarChar(255)
  description  String      @db.VarChar(1000)
  technologies String[]
  image        String      @db.VarChar(500)
  githubUrl    String?     @db.VarChar(500)
  liveUrl      String?     @db.VarChar(500)
  /// Case-study sections shown on /projects/[slug] (plain text, rendered
  /// as paragraphs). All optional — the detail page adapts to what exists.
  overview     String?
  problem      String?
  solution     String?
  outcome      String?
  /// Cloudinary URLs of additional screenshots for the case study.
  screenshots  String[]    @default([])
  /// Optional walkthrough/demo video shown on the detail page.
  youtubeUrl   String?     @db.VarChar(500)
  projectType  ProjectType @default(SIDE)
  /// Whether the source repository is public. When false the public site
  /// hides the "View Code" link even if githubUrl is stored.
  isRepoPublic Boolean     @default(true)
  isPublished  Boolean     @default(false)
  displayOrder Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  /// Soft delete — non-null means the record is archived/hidden.
  deletedAt    DateTime?

  @@index([slug])
  @@index([isPublished])
  @@index([projectType])
  @@index([displayOrder])
  @@index([deletedAt])
}

model Testimonial {
  id           String   @id @default(uuid())
  author       String   @db.VarChar(150)
  role         String   @db.VarChar(200)
  quote        String   @db.VarChar(2000)
  image        String?  @db.VarChar(500)
  /// Optional social links for the person giving the testimonial.
  /// Shape: [{ "platform": string, "url": string }]
  socials      Json     @default("[]")
  isPublished  Boolean  @default(false)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  /// Soft delete — non-null means the record is archived/hidden.
  deletedAt    DateTime?

  @@index([isPublished])
  @@index([displayOrder])
  @@index([deletedAt])
}

enum UserSecurityTokenType {
  TWO_FACTOR_LOGIN // 6-digit email OTP challenged at login
  TWO_FACTOR_SETUP // 6-digit email OTP confirming 2FA enablement
  PASSWORD_RESET // long random token embedded in the email reset link
}

/// Short-lived, single-use auth tokens. Intentionally HARD-deleted (no
/// soft delete) — keeping spent 2FA/reset tokens around is a security risk.
model UserSecurityToken {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  /// sha256 of the plain code — the plain value is never stored.
  tokenHash String                @unique
  type      UserSecurityTokenType

  attempts    Int @default(0)
  maxAttempts Int @default(5)

  expiresAt  DateTime
  consumedAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId, type])
  @@index([expiresAt])
}
